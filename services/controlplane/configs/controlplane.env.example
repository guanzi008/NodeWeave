CONTROLPLANE_ADDRESS=:8080
CONTROLPLANE_STORAGE_DRIVER=sqlite
CONTROLPLANE_SQLITE_PATH=data/controlplane.db
CONTROLPLANE_ADMIN_EMAIL=admin@example.com
CONTROLPLANE_ADMIN_PASSWORD=dev-password
CONTROLPLANE_ADMIN_TOKEN=dev-admin-token
CONTROLPLANE_REGISTRATION_TOKEN=dev-register-token
CONTROLPLANE_DNS_DOMAIN=internal.net
CONTROLPLANE_RELAYS=relay-ap-1.example.net:3478,relay-us-1.example.net:3478
CONTROLPLANE_EXIT_NODE_ID=
CONTROLPLANE_EXIT_NODE_MODE=enforced
CONTROLPLANE_EXIT_NODE_ALLOW_LAN=true
CONTROLPLANE_EXIT_NODE_ALLOW_INTERNET=true
CONTROLPLANE_EXIT_NODE_DNS_MODE=follow_exit
